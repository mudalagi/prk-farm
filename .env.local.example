NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cross-subdomain cookie scope. Set in production so auth cookies survive a
# redirect between the platform apex and tenant subdomains (e.g. an invite
# email landing on chukta.in then routing to prk.chukta.in). Leave unset
# in local dev — browsers ignore `domain` for localhost.
# AUTH_COOKIE_DOMAIN=.chukta.in
